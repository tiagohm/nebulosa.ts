{
	"name": "nebulosa",
	"version": "0.1.0",
	"type": "module",
	"sideEffects": false,
	"module": "main.ts",
	"scripts": {
		"postinstall": "bun run native/copy.ts",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"tsc": "tsgo --noEmit",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check"
	},
	"devDependencies": {
		"oxfmt": "latest",
		"oxlint": "latest",
		"oxlint-tsgolint": "latest"
	},
	"peerDependencies": {
		"@types/bun": "latest",
		"fast-xml-parser": "latest",
		"typescript": "6"
	},
	"optionalDependencies": {
		"@typescript/native-preview": "latest"
	},
	"overrides": {
		"@typescript/native-preview": "beta"
	}
}
