{
	"name": "nebulosa",
	"version": "0.1.0",
	"type": "module",
	"sideEffects": false,
	"module": "main.ts",
	"scripts": {
		"postinstall": "bun run native/copy.ts",
		"lint": "biome lint --write",
		"tsc": "tsgo --noEmit",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check"
	},
	"devDependencies": {
		"@biomejs/biome": "latest",
		"oxfmt": "latest"
	},
	"peerDependencies": {
		"@types/bun": "latest",
		"fast-xml-parser": "latest",
		"typescript": "6"
	},
	"optionalDependencies": {
		"@typescript/native-preview": "latest"
	},
	"overrides": {
		"@typescript/native-preview": "beta"
	},
	"trustedDependencies": [
		"@biomejs/biome"
	]
}
